{
  "name": "trendmap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'cd backend && python manage.py migrate --noinput && python manage.py runserver 127.0.0.1:${TRENDMAP_BACKEND_PORT:-8010} & backend_pid=$!; trap \"kill $backend_pid\" EXIT INT TERM; vite --host 127.0.0.1 \"$@\"' --",
    "dev:api": "npm run dev",
    "dev:backend": "cd backend && python manage.py migrate --noinput && python manage.py runserver 127.0.0.1:${TRENDMAP_BACKEND_PORT:-8010}",
    "test:backend": "cd backend && python manage.py test trendmap_api",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "playwright": "playwright test",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "jsdom": "^28.1.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
